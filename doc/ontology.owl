<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/cedmar/"
     xml:base="http://www.example.org/cedmar/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:cedmar="http://www.example.org/cedmar/#">
    <owl:Ontology rdf:about="http://www.example.org/cedmar/">
        <owl:versionIRI rdf:resource="http://www.example.org/cedmar/1.0.0"/>
        <dc:creator>Manel Bañó Richart</dc:creator>
        <dc:description xml:lang="en">Ontology for European Medical Devices and In Vitro Diagnostics (MDR/IVDR).</dc:description>
        <dc:publisher>UOC - Universitat Oberta de Catalunya</dc:publisher>
        <dc:title>CEDMAR Medical Device Ontology</dc:title>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <rdfs:comment xml:lang="en">Ontology for European Medical Devices and In Vitro Diagnostics (MDR/IVDR).</rdfs:comment>
        <rdfs:label xml:lang="en">CEDMAR Medical Device Ontology</rdfs:label>
        <owl:versionInfo>1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/publisher -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/publisher"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- http://www.example.org/cedmar/#hasDetectDate -->


    <owl:AnnotationProperty rdf:about="http://www.example.org/cedmar/#hasDetectDate"/>
    


    <!-- http://www.example.org/cedmar/#hasEventDate -->


    <owl:AnnotationProperty rdf:about="http://www.example.org/cedmar/#hasEventDate"/>
    


    <!-- http://www.example.org/cedmar/#hasStartDate -->


    <owl:AnnotationProperty rdf:about="http://www.example.org/cedmar/#hasStartDate"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#sameAs -->


    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#sameAs"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/cedmar/#actionAffectsDevice -->


    <owl:ObjectProperty rdf:about="http://www.example.org/cedmar/#actionAffectsDevice">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:comment xml:lang="en">Inferred property linking action to device.</rdfs:comment>
        <rdfs:label xml:lang="en">action affects device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/cedmar/#causedByRisk -->


    <owl:ObjectProperty rdf:about="http://www.example.org/cedmar/#causedByRisk">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/cedmar/#Risk"/>
        <rdfs:comment xml:lang="en">Relates an incident to the specific IMDRF risk that caused it.</rdfs:comment>
        <rdfs:label xml:lang="en">caused by risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/cedmar/#exposedToRisk -->


    <owl:ObjectProperty rdf:about="http://www.example.org/cedmar/#exposedToRisk">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://www.example.org/cedmar/#Risk"/>
        <rdfs:comment xml:lang="en">Inferred property linking device to risk.</rdfs:comment>
        <rdfs:label xml:lang="en">exposed to risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/cedmar/#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.example.org/cedmar/#hasManufacturer">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://www.example.org/cedmar/#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relates a medical device to its manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/cedmar/#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.example.org/cedmar/#hasRiskClass">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://www.example.org/cedmar/#RiskClass"/>
        <rdfs:comment xml:lang="en">Relates a device to its regulatory risk class.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/cedmar/#involvesDevice -->


    <owl:ObjectProperty rdf:about="http://www.example.org/cedmar/#involvesDevice">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:comment xml:lang="en">Relates an incident to the medical device involved.</rdfs:comment>
        <rdfs:label xml:lang="en">involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/cedmar/#locatedIn -->


    <owl:ObjectProperty rdf:about="http://www.example.org/cedmar/#locatedIn">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Manufacturer"/>
        <rdfs:range rdf:resource="http://dbpedia.org/ontology/Country"/>
        <rdfs:comment xml:lang="en">Relates a manufacturer to its geographical country.</rdfs:comment>
        <rdfs:label xml:lang="en">located in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/cedmar/#manufacturedIn -->


    <owl:ObjectProperty rdf:about="http://www.example.org/cedmar/#manufacturedIn">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://dbpedia.org/ontology/Country"/>
        <rdfs:comment xml:lang="en">Inferred property linking device to country.</rdfs:comment>
        <rdfs:label xml:lang="en">manufactured in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/cedmar/#resolvesIncident -->


    <owl:ObjectProperty rdf:about="http://www.example.org/cedmar/#resolvesIncident">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/cedmar/#Incident"/>
        <rdfs:comment xml:lang="en">Relates a corrective action (FSCA) to the incident it resolves.</rdfs:comment>
        <rdfs:label xml:lang="en">resolves incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/cedmar/#actionTaken -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#actionTaken">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Was action taken.</rdfs:comment>
        <rdfs:label xml:lang="en">action taken</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#devicesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#devicesAffected">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Number of devices affected.</rdfs:comment>
        <rdfs:label xml:lang="en">devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasAuthority -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasAuthority">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Competent authority.</rdfs:comment>
        <rdfs:label xml:lang="en">has authority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasDescription -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasDescription">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">General description.</rdfs:comment>
        <rdfs:label xml:lang="en">has description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasDeviceName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasDeviceName">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Commercial or trade name of the medical device.</rdfs:comment>
        <rdfs:label xml:lang="en">has device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasEmail -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasEmail">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Contact email.</rdfs:comment>
        <rdfs:label xml:lang="en">has email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasEudamedRef -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasEudamedRef">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">EUDAMED URL reference.</rdfs:comment>
        <rdfs:label xml:lang="en">has Eudamed ref</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasFramework -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasFramework">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Regulatory framework MDR/IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">has framework</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasGeoScope -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasGeoScope">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Regions or countries affected by a corrective action.</rdfs:comment>
        <rdfs:label xml:lang="en">has geo scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasLegalName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasLegalName">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Official legal name.</rdfs:comment>
        <rdfs:label xml:lang="en">has legal name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasOutcome -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasOutcome">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Clinical outcome.</rdfs:comment>
        <rdfs:label xml:lang="en">has outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasPatientAge -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasPatientAge">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Age of patient.</rdfs:comment>
        <rdfs:label xml:lang="en">has patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasPatientSex -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasPatientSex">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Sex of patient.</rdfs:comment>
        <rdfs:label xml:lang="en">has patient sex</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasPriority -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasPriority">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Priority of ocurrence</rdfs:comment>
        <rdfs:label xml:lang="en">Has Priority</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasProbability -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasProbability">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Probability of occurrence.</rdfs:comment>
        <rdfs:label xml:lang="en">has probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasPurpose">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Intended purpose.</rdfs:comment>
        <rdfs:label xml:lang="en">has purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasReportDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasReportDate">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Date of report.</rdfs:comment>
        <rdfs:label xml:lang="en">has report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasRiskName -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasRiskName">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Name of the risk.</rdfs:comment>
        <rdfs:label xml:lang="en">has risk name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasSRN -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasSRN">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Single Registration Number.</rdfs:comment>
        <rdfs:label xml:lang="en">has SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasSeverity -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasSeverity">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Severity level.</rdfs:comment>
        <rdfs:label xml:lang="en">has severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasStatus -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasStatus">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Status of the action.</rdfs:comment>
        <rdfs:label xml:lang="en">has status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#hasUDI -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#hasUDI">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique Device Identifier.</rdfs:comment>
        <rdfs:label xml:lang="en">has UDI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#isActive -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#isActive">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Is active device.</rdfs:comment>
        <rdfs:label xml:lang="en">is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#isIVD -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#isIVD">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Is in vitro diagnostic.</rdfs:comment>
        <rdfs:label xml:lang="en">is IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#isImplantable">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Is implantable device.</rdfs:comment>
        <rdfs:label xml:lang="en">is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#isReusable -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#isReusable">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Is reusable device.</rdfs:comment>
        <rdfs:label xml:lang="en">is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/cedmar/#reportedBy -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/cedmar/#reportedBy">
        <rdfs:domain rdf:resource="http://www.example.org/cedmar/#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Reporting entity.</rdfs:comment>
        <rdfs:label xml:lang="en">reported by</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://dbpedia.org/ontology/Country -->


    <owl:Class rdf:about="http://dbpedia.org/ontology/Country">
        <rdfs:comment xml:lang="en">Dbpedia Country</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/cedmar/#ActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/cedmar/#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:comment xml:lang="en">Depends on energy source.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/cedmar/#ActiveImplant -->


    <owl:Class rdf:about="http://www.example.org/cedmar/#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.example.org/cedmar/#Device"/>
        <rdfs:comment xml:lang="en">Active and implantable.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Implant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/cedmar/#ContaminationRisk -->


    <owl:Class rdf:about="http://www.example.org/cedmar/#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/cedmar/#Risk"/>
        <rdfs:comment xml:lang="en">Risk from biological, chemical, or particulate impurities.</rdfs:comment>
        <rdfs:label xml:lang="en">Contamination Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/cedmar/#CorrectiveAction -->


    <owl:Class rdf:about="http://www.example.org/cedmar/#CorrectiveAction">
        <rdfs:comment xml:lang="en">FSCA taken by manufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/cedmar/#CybersecurityRisk -->


    <owl:Class rdf:about="http://www.example.org/cedmar/#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/cedmar/#Risk"/>
        <rdfs:comment xml:lang="en">Unauthorized access.</rdfs:comment>
        <rdfs:label xml:lang="en">Cybersecurity Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/cedmar/#Device -->


    <owl:Class rdf:about="http://www.example.org/cedmar/#Device">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/cedmar/#hasManufacturer"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/cedmar/#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/cedmar/#hasRiskClass"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.example.org/cedmar/#RiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
