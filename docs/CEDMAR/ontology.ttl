@prefix : <http://www.example.org/cedmar#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.example.org/cedmar#> .

<http://www.example.org/cedmar> rdf:type owl:Ontology ;
                                 <http://purl.org/dc/terms/creator> "Manel Baño Richart" ;
                                 <http://purl.org/dc/terms/description> "Ontology for European Medical Devices and In Vitro Diagnostics (MDR/IVDR)."@en ;
                                 <http://purl.org/dc/terms/title> "CEDMAR Medical Device Ontology"@en ;
                                 owl:versionInfo "1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.example.org/cedmar#hasDetectDate
:hasDetectDate rdf:type owl:AnnotationProperty .


###  http://www.example.org/cedmar#hasEventDate
:hasEventDate rdf:type owl:AnnotationProperty .


###  http://www.example.org/cedmar#hasStartDate
:hasStartDate rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#sameAs
rdfs:sameAs rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.example.org/cedmar#actionAffectsDevice
:actionAffectsDevice rdf:type owl:ObjectProperty ;
                     rdfs:domain :CorrectiveAction ;
                     rdfs:range :Device ;
                     rdfs:comment "Inferred property linking action to device."@en ;
                     rdfs:label "action affects device"@en .


###  http://www.example.org/cedmar#causedByRisk
:causedByRisk rdf:type owl:ObjectProperty ;
              rdfs:domain :Incident ;
              rdfs:range :Risk ;
              rdfs:comment "Relates an incident to the specific IMDRF risk that caused it."@en ;
              rdfs:label "caused by risk"@en .


###  http://www.example.org/cedmar#exposedToRisk
:exposedToRisk rdf:type owl:ObjectProperty ;
               rdfs:domain :Device ;
               rdfs:range :Risk ;
               rdfs:comment "Inferred property linking device to risk."@en ;
               rdfs:label "exposed to risk"@en .


###  http://www.example.org/cedmar#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ;
                 rdfs:domain :Device ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Relates a medical device to its manufacturer."@en ;
                 rdfs:label "has manufacturer"@en .


###  http://www.example.org/cedmar#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :Device ;
              rdfs:range :RiskClass ;
              rdfs:comment "Relates a device to its regulatory risk class."@en ;
              rdfs:label "has risk class"@en .


###  http://www.example.org/cedmar#involvesDevice
:involvesDevice rdf:type owl:ObjectProperty ;
                rdfs:domain :Incident ;
                rdfs:range :Device ;
                rdfs:comment "Relates an incident to the medical device involved."@en ;
                rdfs:label "involves device"@en .


###  http://www.example.org/cedmar#locatedIn
:locatedIn rdf:type owl:ObjectProperty ;
           rdfs:domain :Manufacturer ;
           rdfs:range <http://dbpedia.org/ontology/Country> ;
           rdfs:comment "Relates a manufacturer to its geographical country."@en ;
           rdfs:label "located in"@en .


###  http://www.example.org/cedmar#manufacturedIn
:manufacturedIn rdf:type owl:ObjectProperty ;
                rdfs:domain :Device ;
                rdfs:range <http://dbpedia.org/ontology/Country> ;
                rdfs:comment "Inferred property linking device to country."@en ;
                rdfs:label "manufactured in"@en .


###  http://www.example.org/cedmar#resolvesIncident
:resolvesIncident rdf:type owl:ObjectProperty ;
                  rdfs:domain :CorrectiveAction ;
                  rdfs:range :Incident ;
                  rdfs:comment "Relates a corrective action (FSCA) to the incident it resolves."@en ;
                  rdfs:label "resolves incident"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.example.org/cedmar#actionTaken
:actionTaken rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range xsd:boolean ;
             rdfs:comment "Was action taken."@en ;
             rdfs:label "action taken"@en .


###  http://www.example.org/cedmar#devicesAffected
:devicesAffected rdf:type owl:DatatypeProperty ;
                 rdfs:domain :CorrectiveAction ;
                 rdfs:range xsd:integer ;
                 rdfs:comment "Number of devices affected."@en ;
                 rdfs:label "devices affected"@en .


###  http://www.example.org/cedmar#hasAuthority
:hasAuthority rdf:type owl:DatatypeProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string ;
              rdfs:comment "Competent authority."@en ;
              rdfs:label "has authority"@en .


###  http://www.example.org/cedmar#hasDescription
:hasDescription rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:string ;
                rdfs:comment "General description."@en ;
                rdfs:label "has description"@en .


###  http://www.example.org/cedmar#hasDeviceName
:hasDeviceName rdf:type owl:DatatypeProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:string ;
               rdfs:comment "Commercial name."@en ;
               rdfs:label "has device name"@en .


###  http://www.example.org/cedmar#hasEmail
:hasEmail rdf:type owl:DatatypeProperty ;
          rdfs:domain :Manufacturer ;
          rdfs:range xsd:string ;
          rdfs:comment "Contact email."@en ;
          rdfs:label "has email"@en .


###  http://www.example.org/cedmar#hasEudamedRef
:hasEudamedRef rdf:type owl:DatatypeProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:anyURI ;
               rdfs:comment "EUDAMED URL reference."@en ;
               rdfs:label "has Eudamed ref"@en .


###  http://www.example.org/cedmar#hasFramework
:hasFramework rdf:type owl:DatatypeProperty ;
              rdfs:domain :Device ;
              rdfs:range xsd:string ;
              rdfs:comment "Regulatory framework MDR/IVDR."@en ;
              rdfs:label "has framework"@en .


###  http://www.example.org/cedmar#hasGeoScope
:hasGeoScope rdf:type owl:DatatypeProperty ;
             rdfs:domain :CorrectiveAction ;
             rdfs:range xsd:string ;
             rdfs:comment "Geographic scope."@en ;
             rdfs:label "has geo scope"@en .


###  http://www.example.org/cedmar#hasLegalName
:hasLegalName rdf:type owl:DatatypeProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range xsd:string ;
              rdfs:comment "Official legal name."@en ;
              rdfs:label "has legal name"@en ,
                         "nom legal" .


###  http://www.example.org/cedmar#hasOutcome
:hasOutcome rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Clinical outcome."@en ;
            rdfs:label "has outcome"@en .


###  http://www.example.org/cedmar#hasPatientAge
:hasPatientAge rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:integer ;
               rdfs:comment "Age of patient."@en ;
               rdfs:label "has patient age"@en .


###  http://www.example.org/cedmar#hasPatientSex
:hasPatientSex rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:string ;
               rdfs:comment "Sex of patient."@en ;
               rdfs:label "has patient sex"@en .


###  http://www.example.org/cedmar#hasPriority
:hasPriority rdf:type owl:DatatypeProperty ;
             rdfs:domain :Incident ;
             rdfs:range xsd:string ;
             rdfs:label "té prioritat" .


###  http://www.example.org/cedmar#hasProbability
:hasProbability rdf:type owl:DatatypeProperty ;
                rdfs:domain :Risk ;
                rdfs:range xsd:string ;
                rdfs:comment "Probability of occurrence."@en ;
                rdfs:label "has probability"@en .


###  http://www.example.org/cedmar#hasPurpose
:hasPurpose rdf:type owl:DatatypeProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:string ;
            rdfs:comment "Intended purpose."@en ;
            rdfs:label "has purpose"@en .


###  http://www.example.org/cedmar#hasReportDate
:hasReportDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:dateTime ;
               rdfs:comment "Date of report."@en ;
               rdfs:label "has report date"@en ,
                          "data de report" .


###  http://www.example.org/cedmar#hasRiskName
:hasRiskName rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "Name of the risk."@en ;
             rdfs:label "has risk name"@en .


###  http://www.example.org/cedmar#hasSRN
:hasSRN rdf:type owl:DatatypeProperty ;
        rdfs:domain :Manufacturer ;
        rdfs:range xsd:string ;
        rdfs:comment "Single Registration Number."@en ;
        rdfs:label "has SRN"@en .


###  http://www.example.org/cedmar#hasSeverity
:hasSeverity rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "Severity level."@en ;
             rdfs:label "has severity"@en .


###  http://www.example.org/cedmar#hasStatus
:hasStatus rdf:type owl:DatatypeProperty ;
           rdfs:domain :CorrectiveAction ;
           rdfs:range xsd:string ;
           rdfs:comment "Status of the action."@en ;
           rdfs:label "has status"@en .


###  http://www.example.org/cedmar#hasUDI
:hasUDI rdf:type owl:DatatypeProperty ;
        rdfs:domain :Device ;
        rdfs:range xsd:string ;
        rdfs:comment "Unique Device Identifier."@en ;
        rdfs:label "has UDI"@en ,
                   "té codi UDI" .


###  http://www.example.org/cedmar#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Is active device."@en ;
          rdfs:label "is active"@en .


###  http://www.example.org/cedmar#isIVD
:isIVD rdf:type owl:DatatypeProperty ;
       rdfs:domain :Device ;
       rdfs:range xsd:boolean ;
       rdfs:comment "Is in vitro diagnostic."@en ;
       rdfs:label "is IVD"@en .


###  http://www.example.org/cedmar#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Is implantable device."@en ;
               rdfs:label "is implantable"@en .


###  http://www.example.org/cedmar#isReusable
:isReusable rdf:type owl:DatatypeProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Is reusable device."@en ;
            rdfs:label "is reusable"@en .


###  http://www.example.org/cedmar#reportedBy
:reportedBy rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "Reporting entity."@en ;
            rdfs:label "reported by"@en .


#################################################################
#    Classes
#################################################################

###  http://dbpedia.org/ontology/Country
<http://dbpedia.org/ontology/Country> rdf:type owl:Class .


###  http://www.example.org/cedmar#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :Device ;
              rdfs:comment "Depends on energy source."@en ;
              rdfs:label "Active Device"@en .


###  http://www.example.org/cedmar#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :Device ;
               rdfs:comment "Active and implantable."@en ;
               rdfs:label "Active Implant"@en .


###  http://www.example.org/cedmar#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Contamination."@en ;
                   rdfs:label "Contamination Risk"@en .


###  http://www.example.org/cedmar#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:comment "FSCA taken by manufacturer."@en ;
                  rdfs:label "Corrective Action"@en .


###  http://www.example.org/cedmar#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Unauthorized access."@en ;
                   rdfs:label "Cybersecurity Risk"@en .


###  http://www.example.org/cedmar#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturer ;
                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Manufacturer
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasRiskClass ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :RiskClass
                        ] ;
        rdfs:comment "Instrument intended for medical purposes."@en ,
                     "Qualsevol instrument, aparell o programari destinat a fins mèdics segons MDR."@ca ;
        rdfs:label "Dispositiu Mèdic"@ca ,
                   "Medical Device"@en .


###  http://www.example.org/cedmar#DeviceFailure
:DeviceFailure rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Failure to perform."@en ;
               rdfs:label "Device Failure"@en .


###  http://www.example.org/cedmar#DevicePerformance
:DevicePerformance rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Degradation in performance."@en ;
                   rdfs:label "Device Performance Risk"@en .


###  http://www.example.org/cedmar#DeviceSafety
:DeviceSafety rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "General safety risk."@en ;
              rdfs:label "Device Safety Risk"@en .


###  http://www.example.org/cedmar#DiagnosticError
:DiagnosticError rdf:type owl:Class ;
                 rdfs:subClassOf :Risk ;
                 rdfs:comment "Error in diagnosis."@en ;
                 rdfs:label "Diagnostic Error"@en .


###  http://www.example.org/cedmar#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "Risk in IVD."@en ;
                rdfs:label "Diagnostic Risk"@en .


###  http://www.example.org/cedmar#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :Device ;
                   rdfs:comment "Introduced into body."@en ;
                   rdfs:label "Implantable Device"@en .


###  http://www.example.org/cedmar#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :CorrectiveAction ;
                  rdfs:comment "Modification at facility."@en ;
                  rdfs:label "In Situ Correction"@en .


###  http://www.example.org/cedmar#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :Device ;
                         rdfs:comment "Examination of specimens."@en ;
                         rdfs:label "IVD Device"@en .


###  http://www.example.org/cedmar#Incident
:Incident rdf:type owl:Class ;
          rdfs:comment "Esdeveniment que afecta la seguretat o el funcionament normal del dispositiu."@ca ,
                       "Vigilance event."@en ;
          rdfs:label "Incident"@en ,
                     "Incident de Vigilància"@ca .


###  http://www.example.org/cedmar#InfectionRisk
:InfectionRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Risk of infection."@en ;
               rdfs:label "Infection Risk"@en .


###  http://www.example.org/cedmar#InferenceRisk
:InferenceRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk .


###  http://www.example.org/cedmar#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :Risk ;
            rdfs:comment "Risk of injury."@en ;
            rdfs:label "Injury Risk"@en .


###  http://www.example.org/cedmar#InterferenceRisk
:InterferenceRisk rdf:type owl:Class ;
                  rdfs:subClassOf :Risk ;
                  rdfs:comment "EMI interference."@en ;
                  rdfs:label "Interference Risk"@en .


###  http://www.example.org/cedmar#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :Risk ;
                 rdfs:comment "Mechanical/electrical malfunction."@en ;
                 rdfs:label "Malfunction Risk"@en .


###  http://www.example.org/cedmar#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:comment "Legal entity responsible for device."@en ;
              rdfs:label "Manufacturer"@en .


###  http://www.example.org/cedmar#MaterialRisk
:MaterialRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Material degradation."@en ;
              rdfs:label "Material Risk"@en .


###  http://www.example.org/cedmar#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident ;
                  rdfs:comment "Could have caused harm."@en ;
                  rdfs:label "Near Miss Incident"@en .


###  http://www.example.org/cedmar#PatientHarm
:PatientHarm rdf:type owl:Class ;
             rdfs:subClassOf :Risk ;
             rdfs:comment "Physical injury."@en ;
             rdfs:label "Patient Harm"@en .


###  http://www.example.org/cedmar#ProductQuality
:ProductQuality rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "Defects."@en ;
                rdfs:label "Product Quality Risk"@en .


###  http://www.example.org/cedmar#RadiationRisk
:RadiationRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Radiation exposure."@en ;
               rdfs:label "Radiation Risk"@en .


###  http://www.example.org/cedmar#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :CorrectiveAction ;
        rdfs:comment "Return of device."@en ;
        rdfs:label "Recall"@en .


###  http://www.example.org/cedmar#Risk
:Risk rdf:type owl:Class ;
      rdfs:comment "Adverse event or failure."@en ,
                   "Probabilitat d'ocurrència d'un dany i la gravetat d'aquest dany."@ca ;
      rdfs:label "Risc Associat"@ca ,
                 "Risk"@en .


###  http://www.example.org/cedmar#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:comment "Regulatory classification."@en ;
           rdfs:label "Risk Class"@en .


###  http://www.example.org/cedmar#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :CorrectiveAction ;
             rdfs:comment "Field Safety Notice."@en ;
             rdfs:label "Safety Alert"@en .


###  http://www.example.org/cedmar#SelfTestDevice
:SelfTestDevice rdf:type owl:Class ;
                rdfs:subClassOf :Device ;
                rdfs:comment "Used by laypersons."@en ;
                rdfs:label "Self-Test Device"@en .


###  http://www.example.org/cedmar#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident ;
                 rdfs:comment "Led to death or serious injury."@en ;
                 rdfs:label "Serious Incident"@en .


###  http://www.example.org/cedmar#SingleUseDevice
:SingleUseDevice rdf:type owl:Class ;
                 rdfs:subClassOf :Device ;
                 rdfs:comment "Used for single procedure."@en ;
                 rdfs:label "Single Use Device"@en .


###  http://www.example.org/cedmar#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Software anomaly."@en ;
              rdfs:label "Software Risk"@en .


###  http://www.example.org/cedmar#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :CorrectiveAction ;
            rdfs:comment "Information to users."@en ;
            rdfs:label "User Notice"@en .


#################################################################
#    Individuals
#################################################################

###  http://dbpedia.org/resource/Germany
<http://dbpedia.org/resource/Germany> rdf:type owl:NamedIndividual .


###  http://dbpedia.org/resource/Ireland
<http://dbpedia.org/resource/Ireland> rdf:type owl:NamedIndividual .


###  http://www.example.org/cedmar#ClassIII
:ClassIII rdf:type owl:NamedIndividual ,
                   :RiskClass ;
          rdfs:comment "Highest risk class under MDR."@en ;
          rdfs:label "Class III"@en .


###  http://www.example.org/cedmar#ClassIIb
:ClassIIb rdf:type owl:NamedIndividual ,
                   :RiskClass ;
          rdfs:comment "High risk class under MDR."@en ;
          rdfs:label "Class IIb"@en .


###  http://www.example.org/cedmar#DEV-001
:DEV-001 rdf:type owl:NamedIndividual ,
                  :ActiveImplant ;
         :hasManufacturer :MAN-001 ;
         :hasRiskClass :ClassIII ;
         :hasDeviceName "HeartMate 3 LVAD" ;
         :hasUDI "(01)00380740009095" ;
         rdfs:comment "Left ventricular assist device."@en ;
         rdfs:label "HeartMate 3 LVAD"@en .


###  http://www.example.org/cedmar#DEV-002
:DEV-002 rdf:type owl:NamedIndividual ,
                  :ActiveImplant ;
         :hasManufacturer :MAN-001 ;
         :hasRiskClass :ClassIII ;
         :hasDeviceName "Micra AV Transcatheter Pacing System" ;
         :hasFramework "MDR" ;
         :hasPurpose "Leadless cardiac pacemaker for atrioventricular synchrony" ;
         :hasUDI "(01)00380740009112" ;
         :isActive "true"^^xsd:boolean ;
         :isIVD "false"^^xsd:boolean ;
         :isImplantable "true"^^xsd:boolean ;
         :isReusable "false"^^xsd:boolean ;
         rdfs:comment "Leadless cardiac pacemaker."@en ;
         rdfs:label "Micra AV Pacemaker"@en .


###  http://www.example.org/cedmar#FSCA-001
:FSCA-001 rdf:type owl:NamedIndividual ,
                   :SafetyAlert ;
          :resolvesIncident :INC-001 ;
          :hasStatus "Open" ;
          rdfs:comment "Safety alert for HeartMate 3."@en ;
          rdfs:label "FSCA-001"@en .


###  http://www.example.org/cedmar#FSCA-002
:FSCA-002 rdf:type owl:NamedIndividual ,
                   :Recall ;
          :resolvesIncident :INC-002 ;
          :devicesAffected 1240 ;
          :hasDescription "Voluntary recall due to premature battery depletion. Replacement units provided." ;
          :hasEudamedRef "EU-FSCA-2024-000002"^^xsd:anyURI ;
          :hasGeoScope "Micra AV lots manufactured between 2022-09 and 2023-03" ;
          :hasStatus "Closed" ;
          :hasStartDate "2024-02-28T00:00:00"^^xsd:dateTime ;
          rdfs:comment "Recall for Micra AV."@en ;
          rdfs:label "FSCA-002"@en .


###  http://www.example.org/cedmar#INC-001
:INC-001 rdf:type owl:NamedIndividual ,
                  :SeriousIncident ;
         :causedByRisk :RSK-003 ;
         :involvesDevice :DEV-001 ;
         :hasOutcome "Serious patient injury - embolic stroke" ;
         rdfs:comment "Incident for HeartMate 3."@en ;
         rdfs:label "INC-001"@en .


###  http://www.example.org/cedmar#INC-002
:INC-002 rdf:type owl:NamedIndividual ,
                  :SeriousIncident ;
         :causedByRisk :RSK-009 ;
         :involvesDevice :DEV-002 ;
         :actionTaken "true"^^xsd:boolean ;
         :hasEudamedRef "EU-INC-2024-000002"^^xsd:anyURI ;
         :hasOutcome "Device malfunction - premature battery depletion" ;
         :hasPatientAge 72 ;
         :hasPatientSex "Female" ;
         :hasReportDate "2024-02-03T00:00:00"^^xsd:dateTime ;
         :reportedBy "MAN-001" ;
         :hasDetectDate "2024-02-01T00:00:00"^^xsd:dateTime ;
         :hasEventDate "2024-01-29T00:00:00"^^xsd:dateTime ;
         rdfs:comment "Incident for Micra AV."@en ;
         rdfs:label "INC-002"@en .


###  http://www.example.org/cedmar#MAN-001
:MAN-001 rdf:type owl:NamedIndividual ,
                  :Manufacturer ;
         :locatedIn <http://dbpedia.org/resource/Ireland> ;
         :hasAuthority "Health Products Regulatory Authority (HPRA)" ;
         :hasEmail "regulatory@medtronic.com" ;
         :hasLegalName "Medtronic plc" ;
         :hasSRN "SRN-IE-MED-0001" ;
         rdfs:comment "Multinational medical device manufacturer."@en ;
         rdfs:label "Medtronic plc"@en .


###  http://www.example.org/cedmar#MAN-002
:MAN-002 rdf:type owl:NamedIndividual ,
                  :Manufacturer ;
         :locatedIn <http://dbpedia.org/resource/Germany> ;
         :hasLegalName "Abbott Laboratories" ;
         rdfs:comment "Global manufacturer."@en ;
         rdfs:label "Abbott Medical Devices"@en .


###  http://www.example.org/cedmar#RSK-003
:RSK-003 rdf:type owl:NamedIndividual ,
                  :InjuryRisk ;
         :hasRiskName "Thrombosis - device-related" ;
         :hasSeverity "Critical" ;
         rdfs:comment "Thrombus formation on device."@en ;
         rdfs:label "Device-related Thrombosis"@en .


###  http://www.example.org/cedmar#RSK-009
:RSK-009 rdf:type owl:NamedIndividual ,
                  :MalfunctionRisk ;
         :hasDescription "Battery end-of-life earlier than specified, risking therapy interruption" ;
         :hasProbability "Low" ;
         :hasRiskName "Battery depletion - premature" ;
         :hasSeverity "Critical" ;
         rdfs:comment "Battery end-of-life earlier than specified."@en ;
         rdfs:label "Battery depletion - premature"@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <http://dbpedia.org/ontology/Country>
                :CorrectiveAction
                :Device
                :Incident
                :Manufacturer
                :Risk
                :RiskClass
              )
] .


#################################################################
#    Rules
#################################################################

:c rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:i rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:d rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:m rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:r rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "Infers which devices are affected by a corrective action." ;
   rdfs:label "Rule2_ActionAffects" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :CorrectiveAction ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :c
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :resolvesIncident ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :c ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> :i
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :involvesDevice ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> :i ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> :d
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :actionAffectsDevice ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :c ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> :d
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "Infers the manufacturing country of a device based on its manufacturer." ;
