<https://manelnight.github.io/CEDMAR/docs/documentation#c> rdf:type swrl:Variable .

<https://manelnight.github.io/CEDMAR/docs/documentation#i> rdf:type swrl:Variable .

<https://manelnight.github.io/CEDMAR/docs/documentation#d> rdf:type swrl:Variable .

<https://manelnight.github.io/CEDMAR/docs/documentation#m> rdf:type swrl:Variable .

<https://manelnight.github.io/CEDMAR/docs/documentation#r> rdf:type swrl:Variable .

[ swrla:isRuleEnabled "true"^^xsd:boolean ;
   rdfs:comment "Infers the manufacturing country of a device based on its manufacturer." ;
   rdfs:label "Rule3_ManufacturedIn" ;
   rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:ClassAtom ;
                           swrl:classPredicate cedmar:Device ;
                           swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#d>
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                      swrl:propertyPredicate cedmar:locatedIn ;
                                      swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#m> ;
                                      swrl:argument2 <https://manelnight.github.io/CEDMAR/docs/documentation#c>
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                                 swrl:propertyPredicate cedmar:hasManufacturer ;
                                                 swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#d> ;
                                                 swrl:argument2 <https://manelnight.github.io/CEDMAR/docs/documentation#m>
                                               ] ;
                                     rdf:rest rdf:nil
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate cedmar:manufacturedIn ;
                           swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#d> ;
                           swrl:argument2 <https://manelnight.github.io/CEDMAR/docs/documentation#c>
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ swrla:isRuleEnabled "true"^^xsd:boolean ;
   rdfs:comment "Infers the risk a device is exposed to based on its incidents." ;
   rdfs:label "Rule1_ExposedToRisk" ;
   rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate cedmar:causedByRisk ;
                           swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#i> ;
                           swrl:argument2 <https://manelnight.github.io/CEDMAR/docs/documentation#r>
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                      swrl:propertyPredicate cedmar:involvesDevice ;
                                      swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#i> ;
                                      swrl:argument2 <https://manelnight.github.io/CEDMAR/docs/documentation#d>
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:ClassAtom ;
                                                 swrl:classPredicate cedmar:Incident ;
                                                 swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#i>
                                               ] ;
                                     rdf:rest rdf:nil
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate cedmar:exposedToRisk ;
                           swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#d> ;
                           swrl:argument2 <https://manelnight.github.io/CEDMAR/docs/documentation#r>
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

[ swrla:isRuleEnabled "true"^^xsd:boolean ;
   rdfs:comment "Infers which devices are affected by a corrective action." ;
   rdfs:label "Rule2_ActionAffects" ;
   rdf:type swrl:Imp ;
   swrl:body [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate cedmar:resolvesIncident ;
                           swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#c> ;
                           swrl:argument2 <https://manelnight.github.io/CEDMAR/docs/documentation#i>
                         ] ;
               rdf:rest [ rdf:type swrl:AtomList ;
                          rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                                      swrl:propertyPredicate cedmar:involvesDevice ;
                                      swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#i> ;
                                      swrl:argument2 <https://manelnight.github.io/CEDMAR/docs/documentation#d>
                                    ] ;
                          rdf:rest [ rdf:type swrl:AtomList ;
                                     rdf:first [ rdf:type swrl:ClassAtom ;
                                                 swrl:classPredicate cedmar:CorrectiveAction ;
                                                 swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#c>
                                               ] ;
                                     rdf:rest rdf:nil
                                   ]
                        ]
             ] ;
   swrl:head [ rdf:type swrl:AtomList ;
               rdf:first [ rdf:type swrl:IndividualPropertyAtom ;
                           swrl:propertyPredicate cedmar:actionAffectsDevice ;
                           swrl:argument1 <https://manelnight.github.io/CEDMAR/docs/documentation#c> ;
                           swrl:argument2 <https://manelnight.github.io/CEDMAR/docs/documentation#d>
                         ] ;
               rdf:rest rdf:nil
             ]
 ] .

