@prefix : <https://manelnight.github.io/cedmar2/docs/documentation/#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dbo: <http://dbpedia.org/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix swrl: <http://www.w3.org/2003/11/swrl#> .
@prefix swrla: <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#> .
@prefix swrlb: <http://www.w3.org/2003/11/swrlb#> .
@prefix terms: <http://purl.org/dc/terms/> .
@prefix cedmar: <https://manelnight.github.io/cedmar2/docs/documentation/#> .
@prefix dbpedia: <http://dbpedia.org/resource/> .
@base <https://manelnight.github.io/cedmar2/docs/documentation/#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<https://manelnight.github.io/cedmar2/docs/documentation/> rdf:type owl:Ontology ;
                                  owl:versionIRI <https://manelnight.github.io/cedmar2/docs/documentation/1.0.0> ;
                                  dc:creator "Manel Bañó Richart" ;
                                  dc:description "Ontology for European Medical Devices and In Vitro Diagnostics (MDR/IVDR)."@en ;
                                  dc:publisher "UOC - Universitat Oberta de Catalunya" ;
                                  dc:title "CEDMAR Medical Device Ontology" ;
                                  terms:license <https://creativecommons.org/licenses/by/4.0/> ;
								  vann:preferredNamespacePrefix "cedmar" ;
                                  vann:preferredNamespaceUri "https://manelnight.github.io/cedmar2/docs/documentation/#" ;
                                  dcterms:created "2026-04-13"^^xsd:date ;
                                  dcterms:issued "2026-04-13"^^xsd:date ;
                                  rdfs:comment "Ontology for European Medical Devices and In Vitro Diagnostics (MDR/IVDR)."@en ;
                                  rdfs:label "CEDMAR Medical Device Ontology"@en ;
                                  owl:versionInfo "1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/publisher
dc:publisher rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
terms:license rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
swrla:isRuleEnabled rdf:type owl:AnnotationProperty .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasDetectDate
cedmar:hasDetectDate rdf:type owl:AnnotationProperty .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasEventDate
cedmar:hasEventDate rdf:type owl:AnnotationProperty .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasStartDate
cedmar:hasStartDate rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#sameAs
rdfs:sameAs rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://manelnight.github.io/cedmar2/docs/documentation/#actionAffectsDevice
cedmar:actionAffectsDevice rdf:type owl:ObjectProperty ;
                           rdfs:domain cedmar:CorrectiveAction ;
                           rdfs:range cedmar:Device ;
                           rdfs:comment "Inferred property linking action to device."@en ;
                           rdfs:label "action affects device"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#causedByRisk
cedmar:causedByRisk rdf:type owl:ObjectProperty ;
                    rdfs:domain cedmar:Incident ;
                    rdfs:range cedmar:Risk ;
                    rdfs:comment "Relates an incident to the specific IMDRF risk that caused it."@en ;
                    rdfs:label "caused by risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#exposedToRisk
cedmar:exposedToRisk rdf:type owl:ObjectProperty ;
                     rdfs:domain cedmar:Device ;
                     rdfs:range cedmar:Risk ;
                     rdfs:comment "Inferred property linking device to risk."@en ;
                     rdfs:label "exposed to risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasManufacturer
cedmar:hasManufacturer rdf:type owl:ObjectProperty ;
                       rdfs:domain cedmar:Device ;
                       rdfs:range cedmar:Manufacturer ;
                       rdfs:comment "Relates a medical device to its manufacturer."@en ;
                       rdfs:label "has manufacturer"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasRiskClass
cedmar:hasRiskClass rdf:type owl:ObjectProperty ;
                    rdfs:domain cedmar:Device ;
                    rdfs:range cedmar:RiskClass ;
                    rdfs:comment "Relates a device to its regulatory risk class."@en ;
                    rdfs:label "has risk class"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#involvesDevice
cedmar:involvesDevice rdf:type owl:ObjectProperty ;
                      rdfs:domain cedmar:Incident ;
                      rdfs:range cedmar:Device ;
                      rdfs:comment "Relates an incident to the medical device involved."@en ;
                      rdfs:label "involves device"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#locatedIn
cedmar:locatedIn rdf:type owl:ObjectProperty ;
                 rdfs:domain cedmar:Manufacturer ;
                 rdfs:range dbo:Country ;
                 rdfs:comment "Relates a manufacturer to its geographical country."@en ;
                 rdfs:label "located in"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#manufacturedIn
cedmar:manufacturedIn rdf:type owl:ObjectProperty ;
                      rdfs:domain cedmar:Device ;
                      rdfs:range dbo:Country ;
                      rdfs:comment "Inferred property linking device to country."@en ;
                      rdfs:label "manufactured in"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#resolvesIncident
cedmar:resolvesIncident rdf:type owl:ObjectProperty ;
                        rdfs:domain cedmar:CorrectiveAction ;
                        rdfs:range cedmar:Incident ;
                        rdfs:comment "Relates a corrective action (FSCA) to the incident it resolves."@en ;
                        rdfs:label "resolves incident"@en .
						
##### https://manelnight.github.io/cedmar2/docs/documentation/#deviceAffectedByAction
cedmar:deviceAffectedByAction rdf:type owl:ObjectProperty ;
                              owl:inverseOf cedmar:actionAffectsDevice ;
                              rdfs:domain cedmar:Device ;
                              rdfs:range cedmar:CorrectiveAction ;
                              rdfs:comment "Relates a device to the corrective action affecting it."@en ;
                              rdfs:label "device affected by action"@en .

##### https://manelnight.github.io/cedmar2/docs/documentation/#riskCausesIncident
cedmar:riskCausesIncident rdf:type owl:ObjectProperty ;
                          owl:inverseOf cedmar:causedByRisk ;
                          rdfs:domain cedmar:Risk ;
                          rdfs:range cedmar:Incident ;
                          rdfs:comment "Relates a risk to the incident it caused."@en ;
                          rdfs:label "risk causes incident"@en .

##### https://manelnight.github.io/cedmar2/docs/documentation/#riskExposesDevice
cedmar:riskExposesDevice rdf:type owl:ObjectProperty ;
                         owl:inverseOf cedmar:exposedToRisk ;
                         rdfs:domain cedmar:Risk ;
                         rdfs:range cedmar:Device ;
                         rdfs:comment "Relates a risk to the device exposed to it."@en ;
                         rdfs:label "risk exposes device"@en .

##### https://manelnight.github.io/cedmar2/docs/documentation/#isManufacturerOf
cedmar:isManufacturerOf rdf:type owl:ObjectProperty ;
                        owl:inverseOf cedmar:hasManufacturer ;
                        rdfs:domain cedmar:Manufacturer ;
                        rdfs:range cedmar:Device ;
                        rdfs:comment "Relates a manufacturer to the device it produces."@en ;
                        rdfs:label "is manufacturer of"@en .

##### https://manelnight.github.io/cedmar2/docs/documentation/#isRiskClassOf
cedmar:isRiskClassOf rdf:type owl:ObjectProperty ;
                     owl:inverseOf cedmar:hasRiskClass ;
                     rdfs:domain cedmar:RiskClass ;
                     rdfs:range cedmar:Device ;
                     rdfs:comment "Relates a risk class to the device assigned to it."@en ;
                     rdfs:label "is risk class of"@en .

##### https://manelnight.github.io/cedmar2/docs/documentation/#deviceInvolvedIn
cedmar:deviceInvolvedIn rdf:type owl:ObjectProperty ;
                        owl:inverseOf cedmar:involvesDevice ;
                        rdfs:domain cedmar:Device ;
                        rdfs:range cedmar:Incident ;
                        rdfs:comment "Relates a device to the incident it is involved in."@en ;
                        rdfs:label "device involved in"@en .

##### https://manelnight.github.io/cedmar2/docs/documentation/#isLocationOf
cedmar:isLocationOf rdf:type owl:ObjectProperty ;
                    owl:inverseOf cedmar:locatedIn ;
                    rdfs:domain dbo:Country ;
                    rdfs:range cedmar:Manufacturer ;
                    rdfs:comment "Relates a country to the manufacturer located there."@en ;
                    rdfs:label "is location of"@en .

##### https://manelnight.github.io/cedmar2/docs/documentation/#isManufacturingLocationOf
cedmar:isManufacturingLocationOf rdf:type owl:ObjectProperty ;
                                 owl:inverseOf cedmar:manufacturedIn ;
                                 rdfs:domain dbo:Country ;
                                 rdfs:range cedmar:Device ;
                                 rdfs:comment "Relates a country to the device manufactured there."@en ;
                                 rdfs:label "is manufacturing location of"@en .

##### https://manelnight.github.io/cedmar2/docs/documentation/#incidentResolvedBy
cedmar:incidentResolvedBy rdf:type owl:ObjectProperty ;
                          owl:inverseOf cedmar:resolvesIncident ;
                          rdfs:domain cedmar:Incident ;
                          rdfs:range cedmar:CorrectiveAction ;
                          rdfs:comment "Relates an incident to the corrective action that resolves it."@en ;
                          rdfs:label "incident resolved by"@en .
#################################################################
#    Data properties
#################################################################

###  https://manelnight.github.io/cedmar2/docs/documentation/#actionTaken
cedmar:actionTaken rdf:type owl:DatatypeProperty ;
                   rdfs:domain cedmar:Incident ;
                   rdfs:range xsd:boolean ;
                   rdfs:comment "Was action taken."@en ;
                   rdfs:label "action taken"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#devicesAffected
cedmar:devicesAffected rdf:type owl:DatatypeProperty ;
                       rdfs:domain cedmar:CorrectiveAction ;
                       rdfs:range xsd:integer ;
                       rdfs:comment "Number of devices affected."@en ;
                       rdfs:label "devices affected"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasAuthority
cedmar:hasAuthority rdf:type owl:DatatypeProperty ;
                    rdfs:domain cedmar:Manufacturer ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Competent authority."@en ;
                    rdfs:label "has authority"@en .

					  
### https://manelnight.github.io/cedmar2/docs/documentation/#hasDescription
cedmar:hasDescription rdf:type owl:DatatypeProperty ;
                      rdfs:domain owl:Thing ;
                      rdfs:range xsd:string ;
                      rdfs:comment "General description."@en ;
                      rdfs:label "has description"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasDeviceName
cedmar:hasDeviceName rdf:type owl:DatatypeProperty ;
                     rdfs:domain cedmar:Device ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Commercial or trade name of the medical device."@en ;
                     rdfs:label "has device name"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasEmail
cedmar:hasEmail rdf:type owl:DatatypeProperty ;
                rdfs:domain cedmar:Manufacturer ;
                rdfs:range xsd:string ;
                rdfs:comment "Contact email."@en ;
                rdfs:label "has email"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasEudamedRef
cedmar:hasEudamedRef rdf:type owl:DatatypeProperty ;
                     rdfs:domain owl:Thing ;
                     rdfs:range xsd:anyURI ;
                     rdfs:comment "EUDAMED URL reference."@en ;
                     rdfs:label "has Eudamed ref"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasFramework
cedmar:hasFramework rdf:type owl:DatatypeProperty ;
                    rdfs:domain cedmar:Device ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Regulatory framework MDR/IVDR."@en ;
                    rdfs:label "has framework"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasGeoScope
cedmar:hasGeoScope rdf:type owl:DatatypeProperty ;
                   rdfs:domain cedmar:CorrectiveAction ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Regions or countries affected by a corrective action."@en ;
                   rdfs:label "has geo scope"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasLegalName
cedmar:hasLegalName rdf:type owl:DatatypeProperty ;
                    rdfs:domain cedmar:Manufacturer ;
                    rdfs:range xsd:string ;
                    rdfs:comment "Official legal name."@en ;
                    rdfs:label "has legal name"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasOutcome
cedmar:hasOutcome rdf:type owl:DatatypeProperty ;
                  rdfs:domain cedmar:Incident ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Clinical outcome."@en ;
                  rdfs:label "has outcome"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasPatientAge
cedmar:hasPatientAge rdf:type owl:DatatypeProperty ;
                     rdfs:domain cedmar:Incident ;
                     rdfs:range xsd:integer ;
                     rdfs:comment "Age of patient."@en ;
                     rdfs:label "has patient age"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasPatientSex
cedmar:hasPatientSex rdf:type owl:DatatypeProperty ;
                     rdfs:domain cedmar:Incident ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Sex of patient."@en ;
                     rdfs:label "has patient sex"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasPriority
cedmar:hasPriority rdf:type owl:DatatypeProperty ;
                   rdfs:domain cedmar:Incident ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Priority of ocurrence"@en ;
                   rdfs:label "Has Priority"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasProbability
cedmar:hasProbability rdf:type owl:DatatypeProperty ;
                      rdfs:domain cedmar:Risk ;
                      rdfs:range xsd:string ;
                      rdfs:comment "Probability of occurrence."@en ;
                      rdfs:label "has probability"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasPurpose
cedmar:hasPurpose rdf:type owl:DatatypeProperty ;
                  rdfs:domain cedmar:Device ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Intended purpose."@en ;
                  rdfs:label "has purpose"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasReportDate
cedmar:hasReportDate rdf:type owl:DatatypeProperty ;
                     rdfs:domain cedmar:Incident ;
                     rdfs:range xsd:dateTime ;
                     rdfs:comment "Date of report."@en ;
                     rdfs:label "has report date"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasRiskName
cedmar:hasRiskName rdf:type owl:DatatypeProperty ;
                   rdfs:domain cedmar:Risk ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Name of the risk."@en ;
                   rdfs:label "has risk name"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasSRN
cedmar:hasSRN rdf:type owl:DatatypeProperty ;
              rdfs:domain cedmar:Manufacturer ;
              rdfs:range xsd:string ;
              rdfs:comment "Single Registration Number."@en ;
              rdfs:label "has SRN"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasSeverity
cedmar:hasSeverity rdf:type owl:DatatypeProperty ;
                   rdfs:domain cedmar:Risk ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Severity level."@en ;
                   rdfs:label "has severity"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasStatus
cedmar:hasStatus rdf:type owl:DatatypeProperty ;
                 rdfs:domain cedmar:CorrectiveAction ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Status of the action."@en ;
                 rdfs:label "has status"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#hasUDI
cedmar:hasUDI rdf:type owl:DatatypeProperty ;
              rdfs:domain cedmar:Device ;
              rdfs:range xsd:string ;
              rdfs:comment "Unique Device Identifier."@en ;
              rdfs:label "has UDI"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#isActive
cedmar:isActive rdf:type owl:DatatypeProperty ;
                rdfs:domain cedmar:Device ;
                rdfs:range xsd:boolean ;
                rdfs:comment "Is active device."@en ;
                rdfs:label "is active"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#isIVD
cedmar:isIVD rdf:type owl:DatatypeProperty ;
             rdfs:domain cedmar:Device ;
             rdfs:range xsd:boolean ;
             rdfs:comment "Is in vitro diagnostic."@en ;
             rdfs:label "is IVD"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#isImplantable
cedmar:isImplantable rdf:type owl:DatatypeProperty ;
                     rdfs:domain cedmar:Device ;
                     rdfs:range xsd:boolean ;
                     rdfs:comment "Is implantable device."@en ;
                     rdfs:label "is implantable"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#isReusable
cedmar:isReusable rdf:type owl:DatatypeProperty ;
                  rdfs:domain cedmar:Device ;
                  rdfs:range xsd:boolean ;
                  rdfs:comment "Is reusable device."@en ;
                  rdfs:label "is reusable"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#reportedBy
cedmar:reportedBy rdf:type owl:DatatypeProperty ;
                  rdfs:domain cedmar:Incident ;
                  rdfs:range xsd:string ;
                  rdfs:comment "Reporting entity."@en ;
                  rdfs:label "reported by"@en .


#################################################################
#    Classes
#################################################################

###  http://dbpedia.org/ontology/Country
dbo:Country rdf:type owl:Class ;
            rdfs:comment "Dbpedia Country"@en ;
            rdfs:label "Country"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#ActiveDevice
cedmar:ActiveDevice rdf:type owl:Class ;
                    rdfs:subClassOf cedmar:Device ;
                    rdfs:comment "Depends on energy source."@en ;
                    rdfs:label "Active Device"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#ActiveImplant
cedmar:ActiveImplant rdf:type owl:Class ;
                     rdfs:subClassOf cedmar:Device ;
                     rdfs:comment "Active and implantable."@en ;
                     rdfs:label "Active Implant"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#ContaminationRisk
cedmar:ContaminationRisk rdf:type owl:Class ;
                         rdfs:subClassOf cedmar:Risk ;
                         rdfs:comment "Risk from biological, chemical, or particulate impurities."@en ;
                         rdfs:label "Contamination Risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#CorrectiveAction
cedmar:CorrectiveAction rdf:type owl:Class ;
                        rdfs:comment "FSCA taken by manufacturer."@en ;
                        rdfs:label "Corrective Action"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#CybersecurityRisk
cedmar:CybersecurityRisk rdf:type owl:Class ;
                         rdfs:subClassOf cedmar:Risk ;
                         rdfs:comment "Unauthorized access."@en ;
                         rdfs:label "Cybersecurity Risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#Device
cedmar:Device rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty cedmar:hasManufacturer ;
                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass cedmar:Manufacturer
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty cedmar:hasRiskClass ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass cedmar:RiskClass
                              ] ;
              rdfs:comment "Instrument intended for medical purposes."@en ;
              rdfs:label "Medical Device"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#DeviceFailure
cedmar:DeviceFailure rdf:type owl:Class ;
                     rdfs:subClassOf cedmar:Risk ;
                     rdfs:comment "Failure to perform."@en ;
                     rdfs:label "Device Failure"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#DevicePerformance
cedmar:DevicePerformance rdf:type owl:Class ;
                         rdfs:subClassOf cedmar:Risk ;
                         rdfs:comment "Degradation in performance."@en ;
                         rdfs:label "Device Performance Risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#DeviceSafety
cedmar:DeviceSafety rdf:type owl:Class ;
                    rdfs:subClassOf cedmar:Risk ;
                    rdfs:comment "General safety risk."@en ;
                    rdfs:label "Device Safety Risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#DiagnosticError
cedmar:DiagnosticError rdf:type owl:Class ;
                       rdfs:subClassOf cedmar:Risk ;
                       rdfs:comment "Error in diagnosis."@en ;
                       rdfs:label "Diagnostic Error"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#DiagnosticRisk
cedmar:DiagnosticRisk rdf:type owl:Class ;
                      rdfs:subClassOf cedmar:Risk ;
                      rdfs:comment "Risk in IVD."@en ;
                      rdfs:label "Diagnostic Risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#ImplantableDevice
cedmar:ImplantableDevice rdf:type owl:Class ;
                         rdfs:subClassOf cedmar:Device ;
                         rdfs:comment "Introduced into body."@en ;
                         rdfs:label "Implantable Device"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#InSituCorrection
cedmar:InSituCorrection rdf:type owl:Class ;
                        rdfs:subClassOf cedmar:CorrectiveAction ;
                        rdfs:comment "Modification at facility."@en ;
                        rdfs:label "In Situ Correction"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#InVitroDiagnosticDevice
cedmar:InVitroDiagnosticDevice rdf:type owl:Class ;
                               rdfs:subClassOf cedmar:Device ;
                               rdfs:comment "Examination of specimens."@en ;
                               rdfs:label "IVD Device"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#Incident
cedmar:Incident rdf:type owl:Class ;
                rdfs:comment "Vigilance event."@en ;
                rdfs:label "Incident"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#InfectionRisk
cedmar:InfectionRisk rdf:type owl:Class ;
                     rdfs:subClassOf cedmar:Risk ;
                     rdfs:comment "Risk of infection."@en ;
                     rdfs:label "Infection Risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#InferenceRisk
cedmar:InferenceRisk rdf:type owl:Class ;
                     rdfs:subClassOf cedmar:Risk ;
                     rdfs:comment "Risk derived from the data inference processes in medical software."@en ;
                     rdfs:label "Inference Risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#InjuryRisk
cedmar:InjuryRisk rdf:type owl:Class ;
                  rdfs:subClassOf cedmar:Risk ;
                  rdfs:comment "Risk of injury."@en ;
                  rdfs:label "Injury Risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#InterferenceRisk
cedmar:InterferenceRisk rdf:type owl:Class ;
                        rdfs:subClassOf cedmar:Risk ;
                        rdfs:comment "EMI interference."@en ;
                        rdfs:label "Interference Risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#MalfunctionRisk
cedmar:MalfunctionRisk rdf:type owl:Class ;
                       rdfs:subClassOf cedmar:Risk ;
                       rdfs:comment "Mechanical/electrical malfunction."@en ;
                       rdfs:label "Malfunction Risk"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#Manufacturer
cedmar:Manufacturer rdf:type owl:Class ;
                    rdfs:comment "Legal entity responsible for device."@en ;
                    rdfs:label "Manufacturer"@en .


###  https://manelnight.github.io/cedmar2/docs/documentation/#MaterialRisk
cedmar:MaterialRisk rdf:type owl:Class ;
                    rdfs:subClassOf cedmar:Risk ;
                    rdfs:comment "Material degradation."@en ;
                    rdfs:label "Material Risk"@en .


