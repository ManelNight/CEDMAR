@prefix : <http://www.example.org/cedmar/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.example.org/cedmar/> .

<http://www.example.org/cedmar/> rdf:type owl:Ontology ;
                                  owl:versionIRI <http://www.example.org/cedmar/1.0.0> ;
                                  <http://purl.org/dc/elements/1.1/creator> "Manel Bañó Richart" ;
                                  <http://purl.org/dc/elements/1.1/description> "Ontology for European Medical Devices and In Vitro Diagnostics (MDR/IVDR)."@en ;
                                  <http://purl.org/dc/elements/1.1/publisher> "UOC - Universitat Oberta de Catalunya" ;
                                  <http://purl.org/dc/elements/1.1/title> "CEDMAR Medical Device Ontology" ;
                                  <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                  rdfs:comment "Ontology for European Medical Devices and In Vitro Diagnostics (MDR/IVDR)."@en ;
                                  rdfs:label "CEDMAR Medical Device Ontology"@en ;
                                  owl:versionInfo "1.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
<http://purl.org/dc/elements/1.1/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
<http://purl.org/dc/elements/1.1/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/publisher
<http://purl.org/dc/elements/1.1/publisher> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


###  http://www.example.org/cedmar/#hasDetectDate
<http://www.example.org/cedmar/#hasDetectDate> rdf:type owl:AnnotationProperty .


###  http://www.example.org/cedmar/#hasEventDate
<http://www.example.org/cedmar/#hasEventDate> rdf:type owl:AnnotationProperty .


###  http://www.example.org/cedmar/#hasStartDate
<http://www.example.org/cedmar/#hasStartDate> rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2000/01/rdf-schema#sameAs
rdfs:sameAs rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.example.org/cedmar/#actionAffectsDevice
<http://www.example.org/cedmar/#actionAffectsDevice> rdf:type owl:ObjectProperty ;
                                                     rdfs:domain <http://www.example.org/cedmar/#CorrectiveAction> ;
                                                     rdfs:range <http://www.example.org/cedmar/#Device> ;
                                                     rdfs:comment "Inferred property linking action to device."@en ;
                                                     rdfs:label "action affects device"@en .


###  http://www.example.org/cedmar/#causedByRisk
<http://www.example.org/cedmar/#causedByRisk> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <http://www.example.org/cedmar/#Incident> ;
                                              rdfs:range <http://www.example.org/cedmar/#Risk> ;
                                              rdfs:comment "Relates an incident to the specific IMDRF risk that caused it."@en ;
                                              rdfs:label "caused by risk"@en .


###  http://www.example.org/cedmar/#exposedToRisk
<http://www.example.org/cedmar/#exposedToRisk> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                               rdfs:range <http://www.example.org/cedmar/#Risk> ;
                                               rdfs:comment "Inferred property linking device to risk."@en ;
                                               rdfs:label "exposed to risk"@en .


###  http://www.example.org/cedmar/#hasManufacturer
<http://www.example.org/cedmar/#hasManufacturer> rdf:type owl:ObjectProperty ;
                                                 rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                                 rdfs:range <http://www.example.org/cedmar/#Manufacturer> ;
                                                 rdfs:comment "Relates a medical device to its manufacturer."@en ;
                                                 rdfs:label "has manufacturer"@en .


###  http://www.example.org/cedmar/#hasRiskClass
<http://www.example.org/cedmar/#hasRiskClass> rdf:type owl:ObjectProperty ;
                                              rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                              rdfs:range <http://www.example.org/cedmar/#RiskClass> ;
                                              rdfs:comment "Relates a device to its regulatory risk class."@en ;
                                              rdfs:label "has risk class"@en .


###  http://www.example.org/cedmar/#involvesDevice
<http://www.example.org/cedmar/#involvesDevice> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <http://www.example.org/cedmar/#Incident> ;
                                                rdfs:range <http://www.example.org/cedmar/#Device> ;
                                                rdfs:comment "Relates an incident to the medical device involved."@en ;
                                                rdfs:label "involves device"@en .


###  http://www.example.org/cedmar/#locatedIn
<http://www.example.org/cedmar/#locatedIn> rdf:type owl:ObjectProperty ;
                                           rdfs:domain <http://www.example.org/cedmar/#Manufacturer> ;
                                           rdfs:range <http://dbpedia.org/ontology/Country> ;
                                           rdfs:comment "Relates a manufacturer to its geographical country."@en ;
                                           rdfs:label "located in"@en .


###  http://www.example.org/cedmar/#manufacturedIn
<http://www.example.org/cedmar/#manufacturedIn> rdf:type owl:ObjectProperty ;
                                                rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                                rdfs:range <http://dbpedia.org/ontology/Country> ;
                                                rdfs:comment "Inferred property linking device to country."@en ;
                                                rdfs:label "manufactured in"@en .


###  http://www.example.org/cedmar/#resolvesIncident
<http://www.example.org/cedmar/#resolvesIncident> rdf:type owl:ObjectProperty ;
                                                  rdfs:domain <http://www.example.org/cedmar/#CorrectiveAction> ;
                                                  rdfs:range <http://www.example.org/cedmar/#Incident> ;
                                                  rdfs:comment "Relates a corrective action (FSCA) to the incident it resolves."@en ;
                                                  rdfs:label "resolves incident"@en .


#################################################################
#    Data properties
#################################################################

###  http://www.example.org/cedmar/#actionTaken
<http://www.example.org/cedmar/#actionTaken> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <http://www.example.org/cedmar/#Incident> ;
                                             rdfs:range xsd:boolean ;
                                             rdfs:comment "Was action taken."@en ;
                                             rdfs:label "action taken"@en .


###  http://www.example.org/cedmar/#devicesAffected
<http://www.example.org/cedmar/#devicesAffected> rdf:type owl:DatatypeProperty ;
                                                 rdfs:domain <http://www.example.org/cedmar/#CorrectiveAction> ;
                                                 rdfs:range xsd:integer ;
                                                 rdfs:comment "Number of devices affected."@en ;
                                                 rdfs:label "devices affected"@en .


###  http://www.example.org/cedmar/#hasAuthority
<http://www.example.org/cedmar/#hasAuthority> rdf:type owl:DatatypeProperty ;
                                              rdfs:domain <http://www.example.org/cedmar/#Manufacturer> ;
                                              rdfs:range xsd:string ;
                                              rdfs:comment "Competent authority."@en ;
                                              rdfs:label "has authority"@en .


###  http://www.example.org/cedmar/#hasDescription
<http://www.example.org/cedmar/#hasDescription> rdf:type owl:DatatypeProperty ;
                                                rdfs:range xsd:string ;
                                                rdfs:comment "General description."@en ;
                                                rdfs:label "has description"@en .


###  http://www.example.org/cedmar/#hasDeviceName
<http://www.example.org/cedmar/#hasDeviceName> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                               rdfs:range xsd:string ;
                                               rdfs:comment "Commercial or trade name of the medical device."@en ;
                                               rdfs:label "has device name"@en .


###  http://www.example.org/cedmar/#hasEmail
<http://www.example.org/cedmar/#hasEmail> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <http://www.example.org/cedmar/#Manufacturer> ;
                                          rdfs:range xsd:string ;
                                          rdfs:comment "Contact email."@en ;
                                          rdfs:label "has email"@en .


###  http://www.example.org/cedmar/#hasEudamedRef
<http://www.example.org/cedmar/#hasEudamedRef> rdf:type owl:DatatypeProperty ;
                                               rdfs:range xsd:anyURI ;
                                               rdfs:comment "EUDAMED URL reference."@en ;
                                               rdfs:label "has Eudamed ref"@en .


###  http://www.example.org/cedmar/#hasFramework
<http://www.example.org/cedmar/#hasFramework> rdf:type owl:DatatypeProperty ;
                                              rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                              rdfs:range xsd:string ;
                                              rdfs:comment "Regulatory framework MDR/IVDR."@en ;
                                              rdfs:label "has framework"@en .


###  http://www.example.org/cedmar/#hasGeoScope
<http://www.example.org/cedmar/#hasGeoScope> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <http://www.example.org/cedmar/#CorrectiveAction> ;
                                             rdfs:range xsd:string ;
                                             rdfs:comment "Regions or countries affected by a corrective action."@en ;
                                             rdfs:label "has geo scope"@en .


###  http://www.example.org/cedmar/#hasLegalName
<http://www.example.org/cedmar/#hasLegalName> rdf:type owl:DatatypeProperty ;
                                              rdfs:domain <http://www.example.org/cedmar/#Manufacturer> ;
                                              rdfs:range xsd:string ;
                                              rdfs:comment "Official legal name."@en ;
                                              rdfs:label "has legal name"@en .


###  http://www.example.org/cedmar/#hasOutcome
<http://www.example.org/cedmar/#hasOutcome> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.example.org/cedmar/#Incident> ;
                                            rdfs:range xsd:string ;
                                            rdfs:comment "Clinical outcome."@en ;
                                            rdfs:label "has outcome"@en .


###  http://www.example.org/cedmar/#hasPatientAge
<http://www.example.org/cedmar/#hasPatientAge> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <http://www.example.org/cedmar/#Incident> ;
                                               rdfs:range xsd:integer ;
                                               rdfs:comment "Age of patient."@en ;
                                               rdfs:label "has patient age"@en .


###  http://www.example.org/cedmar/#hasPatientSex
<http://www.example.org/cedmar/#hasPatientSex> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <http://www.example.org/cedmar/#Incident> ;
                                               rdfs:range xsd:string ;
                                               rdfs:comment "Sex of patient."@en ;
                                               rdfs:label "has patient sex"@en .


###  http://www.example.org/cedmar/#hasPriority
<http://www.example.org/cedmar/#hasPriority> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <http://www.example.org/cedmar/#Incident> ;
                                             rdfs:range xsd:string ;
                                             rdfs:comment "Priority of ocurrence"@en ;
                                             rdfs:label "Has Priority"@en .


###  http://www.example.org/cedmar/#hasProbability
<http://www.example.org/cedmar/#hasProbability> rdf:type owl:DatatypeProperty ;
                                                rdfs:domain <http://www.example.org/cedmar/#Risk> ;
                                                rdfs:range xsd:string ;
                                                rdfs:comment "Probability of occurrence."@en ;
                                                rdfs:label "has probability"@en .


###  http://www.example.org/cedmar/#hasPurpose
<http://www.example.org/cedmar/#hasPurpose> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                            rdfs:range xsd:string ;
                                            rdfs:comment "Intended purpose."@en ;
                                            rdfs:label "has purpose"@en .


###  http://www.example.org/cedmar/#hasReportDate
<http://www.example.org/cedmar/#hasReportDate> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <http://www.example.org/cedmar/#Incident> ;
                                               rdfs:range xsd:dateTime ;
                                               rdfs:comment "Date of report."@en ;
                                               rdfs:label "has report date"@en .


###  http://www.example.org/cedmar/#hasRiskName
<http://www.example.org/cedmar/#hasRiskName> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <http://www.example.org/cedmar/#Risk> ;
                                             rdfs:range xsd:string ;
                                             rdfs:comment "Name of the risk."@en ;
                                             rdfs:label "has risk name"@en .


###  http://www.example.org/cedmar/#hasSRN
<http://www.example.org/cedmar/#hasSRN> rdf:type owl:DatatypeProperty ;
                                        rdfs:domain <http://www.example.org/cedmar/#Manufacturer> ;
                                        rdfs:range xsd:string ;
                                        rdfs:comment "Single Registration Number."@en ;
                                        rdfs:label "has SRN"@en .


###  http://www.example.org/cedmar/#hasSeverity
<http://www.example.org/cedmar/#hasSeverity> rdf:type owl:DatatypeProperty ;
                                             rdfs:domain <http://www.example.org/cedmar/#Risk> ;
                                             rdfs:range xsd:string ;
                                             rdfs:comment "Severity level."@en ;
                                             rdfs:label "has severity"@en .


###  http://www.example.org/cedmar/#hasStatus
<http://www.example.org/cedmar/#hasStatus> rdf:type owl:DatatypeProperty ;
                                           rdfs:domain <http://www.example.org/cedmar/#CorrectiveAction> ;
                                           rdfs:range xsd:string ;
                                           rdfs:comment "Status of the action."@en ;
                                           rdfs:label "has status"@en .


###  http://www.example.org/cedmar/#hasUDI
<http://www.example.org/cedmar/#hasUDI> rdf:type owl:DatatypeProperty ;
                                        rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                        rdfs:range xsd:string ;
                                        rdfs:comment "Unique Device Identifier."@en ;
                                        rdfs:label "has UDI"@en .


###  http://www.example.org/cedmar/#isActive
<http://www.example.org/cedmar/#isActive> rdf:type owl:DatatypeProperty ;
                                          rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                          rdfs:range xsd:boolean ;
                                          rdfs:comment "Is active device."@en ;
                                          rdfs:label "is active"@en .


###  http://www.example.org/cedmar/#isIVD
<http://www.example.org/cedmar/#isIVD> rdf:type owl:DatatypeProperty ;
                                       rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                       rdfs:range xsd:boolean ;
                                       rdfs:comment "Is in vitro diagnostic."@en ;
                                       rdfs:label "is IVD"@en .


###  http://www.example.org/cedmar/#isImplantable
<http://www.example.org/cedmar/#isImplantable> rdf:type owl:DatatypeProperty ;
                                               rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                               rdfs:range xsd:boolean ;
                                               rdfs:comment "Is implantable device."@en ;
                                               rdfs:label "is implantable"@en .


###  http://www.example.org/cedmar/#isReusable
<http://www.example.org/cedmar/#isReusable> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.example.org/cedmar/#Device> ;
                                            rdfs:range xsd:boolean ;
                                            rdfs:comment "Is reusable device."@en ;
                                            rdfs:label "is reusable"@en .


###  http://www.example.org/cedmar/#reportedBy
<http://www.example.org/cedmar/#reportedBy> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.example.org/cedmar/#Incident> ;
                                            rdfs:range xsd:string ;
                                            rdfs:comment "Reporting entity."@en ;
                                            rdfs:label "reported by"@en .


#################################################################
#    Classes
#################################################################

###  http://dbpedia.org/ontology/Country
<http://dbpedia.org/ontology/Country> rdf:type owl:Class ;
                                      rdfs:comment "Dbpedia Country"@en ;
                                      rdfs:label "Country"@en .


###  http://www.example.org/cedmar/#ActiveDevice
<http://www.example.org/cedmar/#ActiveDevice> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://www.example.org/cedmar/#Device> ;
                                              rdfs:comment "Depends on energy source."@en ;
                                              rdfs:label "Active Device"@en .


###  http://www.example.org/cedmar/#ActiveImplant
<http://www.example.org/cedmar/#ActiveImplant> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://www.example.org/cedmar/#Device> ;
                                               rdfs:comment "Active and implantable."@en ;
                                               rdfs:label "Active Implant"@en .


###  http://www.example.org/cedmar/#ContaminationRisk
<http://www.example.org/cedmar/#ContaminationRisk> rdf:type owl:Class ;
                                                   rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                                   rdfs:comment "Risk from biological, chemical, or particulate impurities."@en ;
                                                   rdfs:label "Contamination Risk"@en .


###  http://www.example.org/cedmar/#CorrectiveAction
<http://www.example.org/cedmar/#CorrectiveAction> rdf:type owl:Class ;
                                                  rdfs:comment "FSCA taken by manufacturer."@en ;
                                                  rdfs:label "Corrective Action"@en .


###  http://www.example.org/cedmar/#CybersecurityRisk
<http://www.example.org/cedmar/#CybersecurityRisk> rdf:type owl:Class ;
                                                   rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                                   rdfs:comment "Unauthorized access."@en ;
                                                   rdfs:label "Cybersecurity Risk"@en .


###  http://www.example.org/cedmar/#Device
<http://www.example.org/cedmar/#Device> rdf:type owl:Class ;
                                        rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://www.example.org/cedmar/#hasManufacturer> ;
                                                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass <http://www.example.org/cedmar/#Manufacturer>
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://www.example.org/cedmar/#hasRiskClass> ;
                                                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                          owl:onClass <http://www.example.org/cedmar/#RiskClass>
                                                        ] ;
                                        rdfs:comment "Instrument intended for medical purposes."@en ;
                                        rdfs:label "Medical Device"@en .


###  http://www.example.org/cedmar/#DeviceFailure
<http://www.example.org/cedmar/#DeviceFailure> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                               rdfs:comment "Failure to perform."@en ;
                                               rdfs:label "Device Failure"@en .


###  http://www.example.org/cedmar/#DevicePerformance
<http://www.example.org/cedmar/#DevicePerformance> rdf:type owl:Class ;
                                                   rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                                   rdfs:comment "Degradation in performance."@en ;
                                                   rdfs:label "Device Performance Risk"@en .


###  http://www.example.org/cedmar/#DeviceSafety
<http://www.example.org/cedmar/#DeviceSafety> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                              rdfs:comment "General safety risk."@en ;
                                              rdfs:label "Device Safety Risk"@en .


###  http://www.example.org/cedmar/#DiagnosticError
<http://www.example.org/cedmar/#DiagnosticError> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                                 rdfs:comment "Error in diagnosis."@en ;
                                                 rdfs:label "Diagnostic Error"@en .


###  http://www.example.org/cedmar/#DiagnosticRisk
<http://www.example.org/cedmar/#DiagnosticRisk> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                                rdfs:comment "Risk in IVD."@en ;
                                                rdfs:label "Diagnostic Risk"@en .


###  http://www.example.org/cedmar/#ImplantableDevice
<http://www.example.org/cedmar/#ImplantableDevice> rdf:type owl:Class ;
                                                   rdfs:subClassOf <http://www.example.org/cedmar/#Device> ;
                                                   rdfs:comment "Introduced into body."@en ;
                                                   rdfs:label "Implantable Device"@en .


###  http://www.example.org/cedmar/#InSituCorrection
<http://www.example.org/cedmar/#InSituCorrection> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.example.org/cedmar/#CorrectiveAction> ;
                                                  rdfs:comment "Modification at facility."@en ;
                                                  rdfs:label "In Situ Correction"@en .


###  http://www.example.org/cedmar/#InVitroDiagnosticDevice
<http://www.example.org/cedmar/#InVitroDiagnosticDevice> rdf:type owl:Class ;
                                                         rdfs:subClassOf <http://www.example.org/cedmar/#Device> ;
                                                         rdfs:comment "Examination of specimens."@en ;
                                                         rdfs:label "IVD Device"@en .


###  http://www.example.org/cedmar/#Incident
<http://www.example.org/cedmar/#Incident> rdf:type owl:Class ;
                                          rdfs:comment "Vigilance event."@en ;
                                          rdfs:label "Incident"@en .


###  http://www.example.org/cedmar/#InfectionRisk
<http://www.example.org/cedmar/#InfectionRisk> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                               rdfs:comment "Risk of infection."@en ;
                                               rdfs:label "Infection Risk"@en .


###  http://www.example.org/cedmar/#InferenceRisk
<http://www.example.org/cedmar/#InferenceRisk> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                               rdfs:comment "Risk derived from the data inference processes in medical software."@en ;
                                               rdfs:label "Inference Risk"@en .


###  http://www.example.org/cedmar/#InjuryRisk
<http://www.example.org/cedmar/#InjuryRisk> rdf:type owl:Class ;
                                            rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                            rdfs:comment "Risk of injury."@en ;
                                            rdfs:label "Injury Risk"@en .


###  http://www.example.org/cedmar/#InterferenceRisk
<http://www.example.org/cedmar/#InterferenceRisk> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                                  rdfs:comment "EMI interference."@en ;
                                                  rdfs:label "Interference Risk"@en .


###  http://www.example.org/cedmar/#MalfunctionRisk
<http://www.example.org/cedmar/#MalfunctionRisk> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                                 rdfs:comment "Mechanical/electrical malfunction."@en ;
                                                 rdfs:label "Malfunction Risk"@en .


###  http://www.example.org/cedmar/#Manufacturer
<http://www.example.org/cedmar/#Manufacturer> rdf:type owl:Class ;
                                              rdfs:comment "Legal entity responsible for device."@en ;
                                              rdfs:label "Manufacturer"@en .


###  http://www.example.org/cedmar/#MaterialRisk
<http://www.example.org/cedmar/#MaterialRisk> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                              rdfs:comment "Material degradation."@en ;
                                              rdfs:label "Material Risk"@en .


###  http://www.example.org/cedmar/#NearMissIncident
<http://www.example.org/cedmar/#NearMissIncident> rdf:type owl:Class ;
                                                  rdfs:subClassOf <http://www.example.org/cedmar/#Incident> ;
                                                  rdfs:comment "Could have caused harm."@en ;
                                                  rdfs:label "Near Miss Incident"@en .


###  http://www.example.org/cedmar/#PatientHarm
<http://www.example.org/cedmar/#PatientHarm> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                             rdfs:comment "Physical injury."@en ;
                                             rdfs:label "Patient Harm"@en .


###  http://www.example.org/cedmar/#ProductQuality
<http://www.example.org/cedmar/#ProductQuality> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                                rdfs:comment "Defect in manufacturing or performance degradation."@en ;
                                                rdfs:label "Product Quality Risk"@en .


###  http://www.example.org/cedmar/#RadiationRisk
<http://www.example.org/cedmar/#RadiationRisk> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                               rdfs:comment "Radiation exposure."@en ;
                                               rdfs:label "Radiation Risk"@en .


###  http://www.example.org/cedmar/#Recall
<http://www.example.org/cedmar/#Recall> rdf:type owl:Class ;
                                        rdfs:subClassOf <http://www.example.org/cedmar/#CorrectiveAction> ;
                                        rdfs:comment "Return of device."@en ;
                                        rdfs:label "Recall"@en .


###  http://www.example.org/cedmar/#Risk
<http://www.example.org/cedmar/#Risk> rdf:type owl:Class ;
                                      rdfs:comment "Adverse event or failure."@en ;
                                      rdfs:label "Risk"@en .


###  http://www.example.org/cedmar/#RiskClass
<http://www.example.org/cedmar/#RiskClass> rdf:type owl:Class ;
                                           rdfs:comment "Regulatory classification."@en ;
                                           rdfs:label "Risk Class"@en .


###  http://www.example.org/cedmar/#SafetyAlert
<http://www.example.org/cedmar/#SafetyAlert> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://www.example.org/cedmar/#CorrectiveAction> ;
                                             rdfs:comment "Field Safety Notice."@en ;
                                             rdfs:label "Safety Alert"@en .


###  http://www.example.org/cedmar/#SelfTestDevice
<http://www.example.org/cedmar/#SelfTestDevice> rdf:type owl:Class ;
                                                rdfs:subClassOf <http://www.example.org/cedmar/#Device> ;
                                                rdfs:comment "Used by laypersons."@en ;
                                                rdfs:label "Self-Test Device"@en .


###  http://www.example.org/cedmar/#SeriousIncident
<http://www.example.org/cedmar/#SeriousIncident> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://www.example.org/cedmar/#Incident> ;
                                                 rdfs:comment "Led to death or serious injury."@en ;
                                                 rdfs:label "Serious Incident"@en .


###  http://www.example.org/cedmar/#SingleUseDevice
<http://www.example.org/cedmar/#SingleUseDevice> rdf:type owl:Class ;
                                                 rdfs:subClassOf <http://www.example.org/cedmar/#Device> ;
                                                 rdfs:comment "Used for single procedure."@en ;
                                                 rdfs:label "Single Use Device"@en .


###  http://www.example.org/cedmar/#SoftwareRisk
<http://www.example.org/cedmar/#SoftwareRisk> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://www.example.org/cedmar/#Risk> ;
                                              rdfs:comment "Software anomaly."@en ;
                                              rdfs:label "Software Risk"@en .


###  http://www.example.org/cedmar/#UserNotice
<http://www.example.org/cedmar/#UserNotice> rdf:type owl:Class ;
                                            rdfs:subClassOf <http://www.example.org/cedmar/#CorrectiveAction> ;
                                            rdfs:comment "Information to users."@en ;
                                            rdfs:label "User Notice"@en .


