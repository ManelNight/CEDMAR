                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> <http://www.example.org/cedmar/#exposedToRisk> ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <http://www.example.org/cedmar#d> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <http://www.example.org/cedmar#r>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

