[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "Infers which devices are affected by a corrective action." ;
   rdfs:label "Rule2_ActionAffects" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> <http://www.example.org/cedmar/#resolvesIncident> ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <http://www.example.org/cedmar#c> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <http://www.example.org/cedmar#i>
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> <http://www.example.org/cedmar/#involvesDevice> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> <http://www.example.org/cedmar#i> ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> <http://www.example.org/cedmar#d>
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#classPredicate> <http://www.example.org/cedmar/#CorrectiveAction> ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> <http://www.example.org/cedmar#c>
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> <http://www.example.org/cedmar/#actionAffectsDevice> ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> <http://www.example.org/cedmar#c> ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> <http://www.example.org/cedmar#d>
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "Infers the risk a device is exposed to based on its incidents." ;
